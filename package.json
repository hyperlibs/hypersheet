{
  "name": "hypersheet",
  "version": "0.2.0-alpha",
  "description": "HTML-first, spreadsheet-like data grid component library built on Alpine.js and htmx",
  "license": "MIT",
  "author": "Hypersheet Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyperlibs/hypersheet.git"
  },
  "bugs": {
    "url": "https://github.com/hyperlibs/hypersheet/issues"
  },
  "homepage": "https://github.com/hyperlibs/hypersheet#readme",
  "keywords": [
    "alpinejs", "htmx", "grid", "datagrid", "spreadsheet",
    "hypermedia", "inline-editing", "html-first"
  ],
  "main": "dist/hypersheet.js",
  "style": "dist/hypersheet.css",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build:css": "cp src/css/hypersheet.css dist/hypersheet.css && cp src/css/views.css dist/views.css",
    "build:js": "cp src/js/hypersheet.js dist/hypersheet.js",
    "build:providers": "cp src/js/providers.js dist/providers.js",
    "build:schema": "cp src/js/schema.js dist/schema.js",
    "build:views": "cp src/js/views.js dist/views.js",
    "build": "npm run build:css && npm run build:js && npm run build:providers && npm run build:schema && npm run build:views",
    "prepublishOnly": "bun run build",
    "test": "bunx playwright test tests/playwright/keyboard-shortcuts.spec.js --config=tests/playwright/playwright.config.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1"
  }
}
